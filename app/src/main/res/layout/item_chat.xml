<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_chat" android:layout_width="match_parent"
    android:layout_height="wrap_content" android:paddingHorizontal="16dp" android:paddingVertical="6dp">

    <LinearLayout android:id="@+id/bubble_chat" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:orientation="vertical"
        android:padding="12dp" android:elevation="1dp">

        <TextView android:id="@+id/tv_nama" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="2dp"/>

        <TextView android:id="@+id/tv_teks" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="16sp"/>
    </LinearLayout>
</LinearLayout>