<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_terang">

    <!-- AREA ATAS: Panel Indikator Sinyal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:background="@drawable/bg_chat_dia">

        <TextView android:id="@+id/ind_awan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☁️ Awan" android:layout_marginEnd="16dp" />
        <TextView android:id="@+id/ind_lora" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📡 LoRa" android:layout_marginEnd="16dp" />
        <TextView android:id="@+id/ind_wifi" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📱 WiFi" />
    </LinearLayout>

    <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <!-- AREA TENGAH 1: Panel Pemindai Wi-Fi Nearby -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        app:cardCornerRadius="16dp" app:cardElevation="2dp" app:contentPadding="16dp"
        android:layout_marginBottom="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wi-Fi P2P (Jarak Dekat)" android:textStyle="bold" android:textSize="18sp" android:layout_marginBottom="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_setup_nearby" android:layout_width="match_parent" android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:text="Atur Jaringan (Host / Join)" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- AREA TENGAH 2: Panel Pemindai LoRa -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:contentPadding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jembatan LoRa" android:textStyle="bold" android:textSize="18sp" android:layout_marginBottom="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_scan_lora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="Pindai Area (Scan)" />

            <TextView android:id="@+id/tv_status_lora" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Belum terhubung" android:textColor="#888888" android:layout_marginTop="8dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <!-- AREA BAWAH: Tombol Aksi Utama -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_masuk_chat"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="MASUK RUANG KOMUNIKASI"
        android:textStyle="bold"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        android:backgroundTint="#007AFF"/>

</LinearLayout>