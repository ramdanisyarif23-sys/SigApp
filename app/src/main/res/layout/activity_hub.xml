<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btn_lora_setup"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_manage"
        android:contentDescription="Pengaturan LoRa"
        app:tint="#666666" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PILIH PERAN JARINGAN"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_host"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="BUAT JARINGAN (HOST)"
            android:textColor="@color/bg_dark"
            app:backgroundTint="@color/p2p_cyan"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_join"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="CARI JARINGAN (JOIN)"
            android:textColor="@color/p2p_cyan"
            app:backgroundTint="#1A1A1A"
            app:strokeColor="@color/p2p_cyan"
            app:strokeWidth="2dp"
            app:cornerRadius="12dp" />
    </LinearLayout>


</RelativeLayout>